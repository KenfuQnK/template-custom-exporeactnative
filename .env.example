# Copy this file to `.env` and fill in the values you need.
# Only variables prefixed with EXPO_PUBLIC_ are inlined into the app bundle.

# Logger verbosity: debug | info | warn | error
# Defaults to "debug" in development and "warn" in production.
# EXPO_PUBLIC_LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Optional integrations — NOT enabled in this template.
# Each one is documented step-by-step under .ai/features/<feature>/.
# Uncomment and fill the variables when you implement the integration.
#
#   Supabase (auth + database + edge functions) -> .ai/features/supabase-*
#     EXPO_PUBLIC_SUPABASE_URL=
#     EXPO_PUBLIC_SUPABASE_ANON_KEY=
#
#   OpenAI (AI integration). The key is SERVER-SIDE ONLY: set it as a Supabase
#   Edge Function secret, never as EXPO_PUBLIC_* -> .ai/features/openai-integration
#     OPENAI_API_KEY=
#
#   RevenueCat (in-app purchases) -> .ai/features/payment-system
#     EXPO_PUBLIC_RC_GOOGLE_KEY=
#     EXPO_PUBLIC_RC_APPLE_KEY=
# ---------------------------------------------------------------------------
